[filter "media"]
    required = true
    clean = git media clean %f
    smudge = git media smudge %f
[user]
    name = Mac Lockard
    email = maclockard@gmail.com
[core]
    autocrlf = input
    trustctime = false
    pager = delta --syntax-theme='Solarized (dark)'
[diff]
    external = difft
[credential]
    helper = store
[push]
    default = matching
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    required = true
[pull]
    ff = only
[include]
  path = ~/workspace/hex-inc/epd-toolbox/shared/dotfiles-lite/git/gitconfig.snippet
